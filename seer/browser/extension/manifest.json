{
  "manifest_version": 3,
  "name": "Seer Bridge",
  "version": "0.1.0",
  "description": "Connects your browser to the Seer MCP server so AI agents can see and control web pages.",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:7842/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Seer Bridge"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
